# 환경 변수 샘플
# .env 파일로 복사해서 사용하세요

# API 설정
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Ollama 설정 (온디바이스 LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=exaone3.5:7.8b-instruct
OLLAMA_TIMEOUT=120
GENERATION_NUM_PREDICT=640
GENERATION_NUM_CTX=2048
GROUNDING_FILTER_MODEL=exaone3.5:7.8b-instruct
GROUNDING_FILTER_MAX_CONCURRENCY=5

# Civil Complaint LLM-Rubric runtime evaluation
ENABLE_CIVIL_LLM_RUBRIC=true
CIVIL_LLM_RUBRIC_USE_LLM_JUDGE=true
CIVIL_LLM_RUBRIC_VERSION=civil_llm_rubric_q0_q7_v1.0
CIVIL_LLM_RUBRIC_JUDGE_PROMPT_VERSION=judge_prompt_2026_06_18
CIVIL_LLM_RUBRIC_MAX_CONTEXTS=5
CIVIL_LLM_RUBRIC_TEMPERATURE=0.0
ENABLE_PROMETHEUS_RUBRIC_FEEDBACK=true
PROMETHEUS_RUBRIC_TRIGGER_MAX_CHOICE=2.0
PROMETHEUS_RUBRIC_MAX_REGENERATION_ATTEMPTS=1
PROMETHEUS_RUBRIC_TEMPERATURE=0.0

# ChromaDB 설정 (벡터 저장소)
CHROMA_DB_PATH=./data/chroma_db
DEFAULT_CHROMA_COLLECTION=civil_cases_v1

# 임베딩 모델
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda

# 성능 설정
MAX_WORKERS=4
REQUEST_TIMEOUT=60
BATCH_SIZE=32

# 검증 설정
MIN_CONFIDENCE_SCORE=0.5
MAX_RETRY_COUNT=3
